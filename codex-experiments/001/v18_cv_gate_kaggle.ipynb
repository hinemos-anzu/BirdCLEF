{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# BirdCLEF V18 CV Gate Runner\n",
    "\n",
    "This notebook runs the V18 pipeline in `train` mode, saves the SED train predictions, and runs the local CV gate for `w_proto=0.65` vs `w_proto=0.60` before spending a Kaggle LB submission.\n",
    "\n",
    "Kaggle setup:\n",
    "- Add the BirdCLEF 2026 competition dataset as an input.\n",
    "- Internet must be enabled if cloning from GitHub inside the notebook.\n",
    "- This notebook intentionally does not submit anything to Kaggle.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import os\n",
    "\n",
    "REPO_DIR = Path('/kaggle/working/BirdCLEF')\n",
    "BRANCH = 'codex/experiment-001'\n",
    "\n",
    "if not REPO_DIR.exists():\n",
    "    !git clone -b {BRANCH} https://github.com/hinemos-anzu/BirdCLEF.git {REPO_DIR}\n",
    "else:\n",
    "    print(f'Repository already exists: {REPO_DIR}')\n",
    "\n",
    "os.chdir('/kaggle/working')\n",
    "print('cwd =', Path.cwd())\n",
    "print('repo =', REPO_DIR)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Confirm Kaggle input paths.\n",
    "BASE = Path('/kaggle/input/competitions/birdclef-2026')\n",
    "print('BASE exists:', BASE.exists())\n",
    "print('train_soundscapes:', len(list((BASE / 'train_soundscapes').glob('*.ogg'))) if (BASE / 'train_soundscapes').exists() else 'missing')\n",
    "print('test_soundscapes:', len(list((BASE / 'test_soundscapes').glob('*.ogg'))) if (BASE / 'test_soundscapes').exists() else 'missing')\n",
    "print('sample_submission exists:', (BASE / 'sample_submission.csv').exists())\n",
    "print('labels exists:', (BASE / 'train_soundscapes_labels.csv').exists())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Force V18 to train mode for local OOF/CV generation.\n",
    "# This edits only the Kaggle working copy, not GitHub.\n",
    "import re\n",
    "\n",
    "script_path = REPO_DIR / 'birdclef_v18_full_pipeline_oof_codex_ready_fixed.py'\n",
    "text = script_path.read_text(encoding='utf-8')\n",
    "text2 = re.sub(r'MODE\\s*=\\s*[\\\"\\\'](?:train|submit)[\\\"\\\']', 'MODE = \"train\"', text, count=1)\n",
    "if text2 == text:\n",
    "    raise RuntimeError('Could not find MODE assignment in V18 script')\n",
    "script_path.write_text(text2, encoding='utf-8')\n",
    "\n",
    "for line in script_path.read_text(encoding='utf-8').splitlines():\n",
    "    if line.strip().startswith('MODE ='):\n",
    "        print(line)\n",
    "        break\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Run V18\n",
    "\n",
    "This can take a while. Running with `%run` keeps notebook variables such as `sed_preds_tr_aligned`, `oof_proto_probs`, `Y_FULL_aligned`, and `meta_tr` available after the script finishes.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%run /kaggle/working/BirdCLEF/birdclef_v18_full_pipeline_oof_codex_ready_fixed.py\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save artifacts needed by the CLI CV gate.\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "cache_dir = Path('/kaggle/working/cache')\n",
    "cache_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "required_vars = ['sed_preds_tr_aligned', 'oof_proto_probs', 'Y_FULL_aligned', 'meta_tr']\n",
    "missing = [name for name in required_vars if name not in globals()]\n",
    "if missing:\n",
    "    raise RuntimeError(f'Missing expected variables after V18 run: {missing}')\n",
    "\n",
    "np.save(cache_dir / 'sed_preds_tr_aligned.npy', sed_preds_tr_aligned)\n",
    "np.save(cache_dir / 'oof_proto_probs.npy', oof_proto_probs)\n",
    "meta_tr.to_parquet(cache_dir / 'perch_meta.parquet')\n",
    "\n",
    "print('saved:', cache_dir / 'sed_preds_tr_aligned.npy', sed_preds_tr_aligned.shape)\n",
    "print('saved:', cache_dir / 'oof_proto_probs.npy', oof_proto_probs.shape)\n",
    "print('saved:', cache_dir / 'perch_meta.parquet', meta_tr.shape)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run the conservative CV gate for Submit C: w_proto=0.65 vs current LB-best w_proto=0.60.\n",
    "!python /kaggle/working/BirdCLEF/codex-experiments/001/cv_blend_gate_runner.py \\\n",
    "  --sed-oof /kaggle/working/cache/sed_preds_tr_aligned.npy \\\n",
    "  --candidate-w 0.65 \\\n",
    "  --baseline-w 0.60\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Inspect saved gate outputs.\n",
    "import json\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "out_dir = Path('/kaggle/working/codex_experiment_001')\n",
    "table = pd.read_csv(out_dir / 'blend_cv_gate_table.csv')\n",
    "decision = json.loads((out_dir / 'blend_cv_gate_decision.json').read_text())\n",
    "display(table)\n",
    "decision\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Decision Rule\n",
    "\n",
    "Use one LB submission for `w_proto=0.65` only if the output says:\n",
    "\n",
    "```text\n",
    "should_submit: true\n",
    "```\n",
    "\n",
    "The default conservative gate is:\n",
    "\n",
    "```text\n",
    "candidate_lb_proxy_gain >= +0.0010\n",
    "bootstrap_p_win >= 0.65\n",
    "```\n",
    "\n",
    "If `should_submit` is false, keep `w_proto=0.60` or move to the next improvement candidate.\n"
   ]
  }
 ],
